    <style>
      /* Default Colors */
      body {
        background-color: white;
        color: black;
        transition: 0.3s;
      }

      /* Dark Mode Colors */
      body.dark-mode {
        background-color: #1a1a1a;
        color: #ffffff;
      }

      /* Dashboard cards ko bhi dark karne ke liye */
      body.dark-mode .card {
        background-color: #2d2d2d;
        color: white;
        border: 1px solid #444;
      }
      /* Light aur Dark Variable Define karein */
      :root {
        --bg-color: #f4f7f6;
        --card-bg: #ffffff;
        --text-color: #333;
        --sidebar-bg: #2c3e50;
      }

      [data-theme="dark"] {
        --bg-color: #121212;
        --card-bg: #1e1e1e;
        --text-color: #e0e0e0;
        --sidebar-bg: #000000;
      }

      /* In variables ko body aur cards par apply karein */
      body {
        background-color: var(--bg-color) !important;
        color: var(--text-color) !important;
        transition: 0.3s;
      }

      .login-card,
      .card,
      .table {
        background-color: var(--card-bg) !important;
        color: var(--text-color) !important;
        border: 1px solid #444;
      }

      /* Sidebar ke liye */
      .sidebar {
        background-color: var(--sidebar-bg) !important;
      }
      :root {
        --sidebar-bg: #2c3e50;
        --main-bg: #f4f7f6;
        --accent: #3498db;
      }
      body {
        background: var(--main-bg);
        font-family: "Segoe UI", sans-serif;
      }

      /* Login Page (Refer to "login page.png") */
      #loginPage {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: white;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .login-card {
        width: 400px;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        text-align: center;
      }

      /* Layout Setup */
      .sidebar {
        width: 260px;
        height: 100vh;
        background: var(--sidebar-bg);
        color: white;
        position: fixed;
        left: 0;
        top: 0;
        transition: 0.3s;
      }
      .main-content {
        margin-left: 260px;
        padding: 30px;
      }

      /* Sidebar Navigation */
      .sidebar-header {
        padding: 20px;
        font-size: 1.5rem;
        font-weight: bold;
        border-bottom: 1px solid #34495e;
      }
      .nav-link {
        color: #bdc3c7;
        padding: 15px 25px;
        cursor: pointer;
        border-bottom: 1px solid #34495e;
        transition: 0.3s;
      }
      .nav-link:hover,
      .nav-link.active {
        background: #34495e;
        color: white;
      }

      /* Cards & Components */
      .stat-card {
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        text-align: center;
      }
      .hidden {
        display: none !important;
      }
      .btn-custom {
        background: var(--accent);
        color: white;
        border-radius: 8px;
        padding: 10px 20px;
        border: none;
      }
      /* --- DARK MODE STYLES --- */

      /* Jab body par .dark-mode class lagegi, tab ye colors apply honge */
      body.dark-mode {
        background-color: #121212 !important; /* Gehra kala rang */
        color: #ffffff !important; /* Safed text */
      }

      /* Sidebar ko dark karne ke liye */
      body.dark-mode .sidebar {
        background-color: #1f1f1f !important;
        border-right: 1px solid #333;
      }

      /* Dashboard ke cards ko dark karne ke liye */
      body.dark-mode .card {
        background-color: #242424 !important;
        color: white !important;
        border: 1px solid #444 !important;
      }

      /* Inputs aur fields ko dark karne ke liye */
      body.dark-mode input,
      body.dark-mode select {
        background-color: #333 !important;
        color: white !important;
        border: 1px solid #555 !important;
      }
    </style>
  </head>
  <body>
    <div id="loginPage">
      <div class="login-card">
        <div class="mb-4"><span style="font-size: 50px">🔒</span></div>
        <h3 class="mb-3" id="authTitle">Sign In</h3>

        <div id="authInputs">
          <!-- Ye fields hamesha dikhengi -->
          <input
            type="email"
            id="userEmail"
            class="form-control mb-3"
            placeholder="Email Address"
          />

          <!-- Ye fields sirf Registration ke waqt dikhengi -->
          <div id="extraFields" style="display: none">
            <input
              type="text"
              id="userName"
              class="form-control mb-3"
              placeholder="Full Name"
            />
            <input type="date" id="userDOB" class="form-control mb-3" />
          </div>

          <input
            type="password"
            id="userPass"
            class="form-control mb-4"
            placeholder="Password"
          />
        </div>

        <button
          id="authBtn"
          onclick="handleLogin()"
          class="btn btn-primary w-100"
        >
          SIGN IN
        </button>

        <p class="mt-3 small" id="toggleText">
          Create New User
          <a href="javascript:void(0)" onclick="switchToRegister()"
            >Register Here</a
          >
