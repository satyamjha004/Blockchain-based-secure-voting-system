    </div>

    <!-- 3. MAIN CONTENT AREA -->
    <div id="mainContent" class="main-content hidden">
      <!-- DASHBOARD (Refer to "admin panel.png") -->
      <div id="dashboard" class="page-section">
        <h2 class="mb-4">Admin Dashboard</h2>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="stat-card">
              <h3>Users</h3>
              <h2 id="displayUsers">0</h2>
            </div>
          </div>
          <div class="col-md-4">
            <div class="stat-card">
              <h3>Candidates</h3>
              <h2 id="displayCandidates">0</h2>
            </div>
          </div>
        </div>
      </div>

      <!-- VIEW USERS (Refer to "view user.png") -->
      <div id="users" class="page-section hidden">
        <h2 class="mb-4">Registered Users</h2>
        <div class="bg-white p-4 rounded shadow-sm">
          <table class="table">
            <thead class="table-light">
              <tr>
                <th>Full Name</th>
                <th>Email ID</th>
                <th>Date of Birth</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="userTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- ADD CANDIDATE (Refer to "add candidate.png") -->
      <div id="candidates" class="page-section hidden">
        <h2 class="mb-4">Add New Candidate</h2>
        <div class="bg-white p-4 rounded shadow-sm" style="max-width: 600px">
          <label class="form-label">Name</label>
          <input
            type="text"
            id="candName"
            class="form-control mb-3"
            placeholder="Enter Candidate Name"
          />
          <label class="form-label">Location</label>
          <input
            type="text"
            id="candLoc"
            class="form-control mb-4"
            placeholder="Enter City/Location"
          />
          <button class="btn btn-custom w-100" onclick="addCandidate()">
            ADD CANDIDATE
          </button>
        </div>
      </div>
      <div id="voting" class="page-section hidden">
        <h2 class="mb-4">Cast Your Vote</h2>
        <div id="candidateList" class="row g-4">
          <!-- Cards yahan automatically load honge -->
        </div>
      </div>

      <!-- RESULTS (Refer to "result of election.png") -->
      <div id="results" class="page-section hidden">
        <h2 class="mb-4">Election Results</h2>
        <div class="row">
          <div class="col-md-8">
            <div class="card p-4">
              <canvas id="votingChart"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>

